<Window x:Class="SeaImageViewer.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SeaImageViewer"
        Title="{Binding [Viewer.Title], Source={x:Static local:LocalizationManager.Instance}}"
        Icon="app_icon.png"
        Width="1080"
        Height="760"
        MinWidth="720"
        MinHeight="480"
        Background="#101318"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="ViewerButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="62" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="BorderBrush" Value="#374151" />
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2B3645" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#526174" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#111827" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#6B7A90" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Foreground" Value="#243044" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border x:Name="ToolbarBorder"
                DockPanel.Dock="Top"
                Background="#111827"
                BorderBrush="#253244"
                BorderThickness="0,0,0,1"
                Padding="12,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource ViewerButtonStyle}"
                            Content="{Binding [Viewer.Previous], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="Previous_Click" />
                    <Button Style="{StaticResource ViewerButtonStyle}"
                            Content="{Binding [Viewer.Next], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="Next_Click" />
                    <Button x:Name="FitViewerButton"
                            Style="{StaticResource ViewerButtonStyle}"
                            Content="{Binding [Viewer.Fit], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="Fit_Click" />
                    <Button x:Name="ActualSizeViewerButton"
                            Style="{StaticResource ViewerButtonStyle}"
                            Content="{Binding [Viewer.ActualSize], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="ActualSize_Click" />
                    <Button Style="{StaticResource ViewerButtonStyle}"
                            MinWidth="36"
                            Content="-"
                            Click="ZoomOut_Click" />
                    <Button Style="{StaticResource ViewerButtonStyle}"
                            MinWidth="36"
                            Content="+"
                            Click="ZoomIn_Click" />
                </StackPanel>

                <TextBlock x:Name="FileNameText"
                           Grid.Column="1"
                           Margin="14,0"
                           VerticalAlignment="Center"
                           Foreground="#F4F7FB"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock x:Name="ViewerStateText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#AEB8C6" />
            </Grid>
        </Border>

        <Grid Background="#070A0E"
              ContextMenuOpening="ImageSurface_ContextMenuOpening">
            <Grid.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="FullScreenMenuItem"
                              Click="ToggleFullScreen_Click" />
                    <Separator />
                    <MenuItem Header="{Binding [Viewer.Previous], Source={x:Static local:LocalizationManager.Instance}}"
                              Click="Previous_Click" />
                    <MenuItem Header="{Binding [Viewer.Next], Source={x:Static local:LocalizationManager.Instance}}"
                              Click="Next_Click" />
                    <Separator />
                    <MenuItem Header="{Binding [Viewer.Fit], Source={x:Static local:LocalizationManager.Instance}}"
                              Click="Fit_Click" />
                    <MenuItem Header="{Binding [Viewer.ActualSize], Source={x:Static local:LocalizationManager.Instance}}"
                              Click="ActualSize_Click" />
                </ContextMenu>
            </Grid.ContextMenu>

            <TextBlock x:Name="EmptyText"
                       Text="{Binding [Viewer.Loading], Source={x:Static local:LocalizationManager.Instance}}"
                       Foreground="#8E99A8"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <ScrollViewer x:Name="ImageScroller"
                          Background="#070A0E"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="ImageScroller_PreviewMouseWheel"
                          PreviewMouseLeftButtonDown="ImageScroller_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="ImageScroller_PreviewMouseMove"
                          PreviewMouseLeftButtonUp="ImageScroller_PreviewMouseLeftButtonUp"
                          SizeChanged="ImageScroller_SizeChanged">
                <Grid MinWidth="{Binding ElementName=ImageScroller, Path=ViewportWidth}"
                      MinHeight="{Binding ElementName=ImageScroller, Path=ViewportHeight}">
                    <Image x:Name="MainImage"
                           Stretch="Fill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                        </Image.LayoutTransform>
                    </Image>
                </Grid>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
