<Window x:Class="SeaImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SeaImageViewer"
        mc:Ignorable="d"
        Title="Sea Image Viewer"
        Icon="app_icon.png"
        Height="760"
        Width="1180"
        MinHeight="560"
        MinWidth="900"
        Background="#EEF3F7"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D5DEE9" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <DropShadowEffect x:Key="PanelShadow"
                          Color="#152033"
                          BlurRadius="18"
                          ShadowDepth="1"
                          Opacity="0.10" />
        <DropShadowEffect x:Key="ThumbnailShadow"
                          Color="#1F2937"
                          BlurRadius="12"
                          ShadowDepth="1"
                          Opacity="0.08" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#243044" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#64748B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#243044" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Effect="{StaticResource ThumbnailShadow}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#7C9FE8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="6,2,6,8" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="2,1" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#F8FAFC"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Image Source="app_icon.png"
                           Width="24"
                           Height="24"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center" />
                    <Border Width="1"
                            Height="22"
                            Background="#D5DEE9"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="打开目录"
                            Click="OpenFolder_Click" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="刷新"
                            Click="Refresh_Click" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="查看"
                            Click="OpenViewer_Click" />
                    <Button x:Name="FitPreviewButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="适应"
                            Click="FitPreview_Click" />
                    <Button x:Name="ActualSizePreviewButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="1:1"
                            Click="ActualSizePreview_Click" />
                </StackPanel>

                <TextBlock x:Name="CurrentFolderText"
                           Grid.Column="1"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="2"
                         ToolTip="按文件名筛选"
                         TextChanged="SearchTextBox_TextChanged" />
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="#F8FAFC"
                   BorderBrush="{StaticResource PanelBorderBrush}"
                   BorderThickness="0,1,0,0"
                   Foreground="{StaticResource MutedTextBrush}">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalContentAlignment="Right">
                <TextBlock x:Name="ZoomText" Text="-" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="170" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="360" MinWidth="240" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="目录"
                               FontWeight="SemiBold"
                               Margin="12,10,12,8" />
                    <TreeView x:Name="FolderTree"
                              BorderThickness="0"
                              SelectedItemChanged="FolderTree_SelectedItemChanged" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="缩略图" FontWeight="SemiBold" />
                        <TextBlock x:Name="ImageCountText"
                                   Grid.Column="1"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </Grid>

                    <ListBox x:Name="ThumbnailList"
                             BorderThickness="0"
                             Background="#F6F8FB"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="ThumbnailList_SelectionChanged"
                             MouseDoubleClick="ThumbnailList_MouseDoubleClick">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ImageFileItem}">
                                <Grid Width="150" Height="152" Margin="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="102" />
                                        <RowDefinition Height="24" />
                                        <RowDefinition Height="20" />
                                    </Grid.RowDefinitions>

                                    <Border Margin="8,8,8,4"
                                            Background="#F1F5F9"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="Uniform"
                                               Margin="5" />
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding FileName}"
                                               Margin="8,1,8,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="12" />
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding DetailText}"
                                               Margin="8,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="4"
                    Background="#0F1720"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Effect="{StaticResource PanelShadow}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="#111827"
                            BorderBrush="#263445"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock x:Name="SelectedImageText"
                                   Text="预览"
                                   Foreground="#F8FAFC"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <Grid Background="#0B0F14">
                        <TextBlock x:Name="EmptyPreviewText"
                                   Text="选择图片"
                                   Foreground="#AAB4C2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <ScrollViewer x:Name="PreviewScroller"
                                      Background="#0B0F14"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="PreviewScroller_PreviewMouseWheel"
                                      PreviewMouseLeftButtonDown="PreviewScroller_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="PreviewScroller_PreviewMouseMove"
                                      PreviewMouseLeftButtonUp="PreviewScroller_PreviewMouseLeftButtonUp"
                                      SizeChanged="PreviewScroller_SizeChanged">
                            <Grid MinWidth="{Binding ElementName=PreviewScroller, Path=ViewportWidth}"
                                  MinHeight="{Binding ElementName=PreviewScroller, Path=ViewportHeight}">
                                <Image x:Name="PreviewImage"
                                       Stretch="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="PreviewScaleTransform" ScaleX="1" ScaleY="1" />
                                    </Image.LayoutTransform>
                                </Image>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
