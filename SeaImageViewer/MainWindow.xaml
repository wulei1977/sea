<Window x:Class="SeaImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SeaImageViewer"
        mc:Ignorable="d"
        Title="Sea Image Viewer"
        Icon="app_icon.png"
        Height="760"
        Width="1180"
        MinHeight="560"
        MinWidth="900"
        Background="#EEF3F7"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D5DEE9" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <DropShadowEffect x:Key="PanelShadow"
                          Color="#152033"
                          BlurRadius="18"
                          ShadowDepth="1"
                          Opacity="0.10" />
        <DropShadowEffect x:Key="ThumbnailShadow"
                          Color="#1F2937"
                          BlurRadius="12"
                          ShadowDepth="1"
                          Opacity="0.08" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#243044" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#64748B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0,28,0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#243044" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="MaxDropDownHeight" Value="260" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="10,6" />
                        <Setter Property="Foreground" Value="#243044" />
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemChrome"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemChrome" Property="Background" Value="#EFF6FF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemChrome" Property="Background" Value="#DBEAFE" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Content="{Binding [Main.Language], Source={x:Static local:LocalizationManager.Instance}}"
                                                      IsHitTestVisible="False" />
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="#64748B"
                                          Width="8"
                                          Height="4"
                                          Stretch="Fill"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,11,0"
                                          IsHitTestVisible="False" />
                                    <ToggleButton Focusable="False"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0"
                                        Background="#FFFFFF"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer Padding="4"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,5,10,5" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#243044" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         Margin="7,0,0,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M10.5,18 C6.36,18 3,14.64 3,10.5 C3,6.36 6.36,3 10.5,3 C14.64,3 18,6.36 18,10.5 C18,14.64 14.64,18 10.5,18 Z"
                                              Fill="Transparent"
                                              Stroke="#94A3B8"
                                              StrokeThickness="2" />
                                        <Path Data="M16,16 L21,21"
                                              Stroke="#94A3B8"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Effect="{StaticResource ThumbnailShadow}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#7C9FE8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="6,2,6,8" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="2,1" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#F8FAFC"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Image Source="app_icon.png"
                           Width="24"
                           Height="24"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center" />
                    <Border Width="1"
                            Height="22"
                            Background="#D5DEE9"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="{Binding [Main.OpenFolder], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="OpenFolder_Click" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="{Binding [Main.Refresh], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="Refresh_Click" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="{Binding [Main.View], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="OpenViewer_Click" />
                    <Button x:Name="FitPreviewButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="{Binding [Main.Fit], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="FitPreview_Click" />
                    <Button x:Name="ActualSizePreviewButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Content="{Binding [Main.ActualSize], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="ActualSizePreview_Click" />
                    <ComboBox x:Name="LanguageComboBox"
                              Style="{StaticResource ToolbarComboBoxStyle}"
                              Width="128"
                              Margin="4,0,8,0"
                              ItemsSource="{Binding Languages, Source={x:Static local:LocalizationManager.Instance}}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="CultureName"
                              ToolTip="{Binding [Main.Language], Source={x:Static local:LocalizationManager.Instance}}"
                              SelectionChanged="LanguageComboBox_SelectionChanged" />
                </StackPanel>

                <TextBlock x:Name="CurrentFolderText"
                           Grid.Column="1"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="2"
                         ToolTip="{Binding [Main.SearchTooltip], Source={x:Static local:LocalizationManager.Instance}}"
                         TextChanged="SearchTextBox_TextChanged" />
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="#F8FAFC"
                   BorderBrush="{StaticResource PanelBorderBrush}"
                   BorderThickness="0,1,0,0"
                   Foreground="{StaticResource MutedTextBrush}">
            <StatusBarItem>
                <TextBlock x:Name="StatusText"
                           Text="{Binding [Main.Ready], Source={x:Static local:LocalizationManager.Instance}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalContentAlignment="Right">
                <TextBlock x:Name="ZoomText" Text="-" />
            </StatusBarItem>
        </StatusBar>

        <Grid x:Name="MainLayoutGrid" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FolderColumn" Width="240" MinWidth="170" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="ThumbnailsColumn" Width="*" MinWidth="240" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="PreviewColumn" Width="400" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding [Main.FolderSection], Source={x:Static local:LocalizationManager.Instance}}"
                               FontWeight="SemiBold"
                               Margin="12,10,12,8" />
                    <TreeView x:Name="FolderTree"
                              BorderThickness="0"
                              SelectedItemChanged="FolderTree_SelectedItemChanged" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          DragCompleted="MainLayoutSplitter_DragCompleted" />

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding [Main.ThumbnailsSection], Source={x:Static local:LocalizationManager.Instance}}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="ImageCountText"
                                   Grid.Column="1"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </Grid>

                    <ListBox x:Name="ThumbnailList"
                             BorderThickness="0"
                             Background="#F6F8FB"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="ThumbnailList_SelectionChanged"
                             MouseDoubleClick="ThumbnailList_MouseDoubleClick">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ImageFileItem}">
                                <Grid Width="150" Height="152" Margin="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="102" />
                                        <RowDefinition Height="24" />
                                        <RowDefinition Height="20" />
                                    </Grid.RowDefinitions>

                                    <Border Margin="8,8,8,4"
                                            Background="#F1F5F9"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="Uniform"
                                               Margin="5" />
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding FileName}"
                                               Margin="8,1,8,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="12" />
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding DetailText}"
                                               Margin="8,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          DragCompleted="MainLayoutSplitter_DragCompleted" />

            <Border Grid.Column="4"
                    Background="#0F1720"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Effect="{StaticResource PanelShadow}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="#111827"
                            BorderBrush="#263445"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock x:Name="SelectedImageText"
                                   Text="{Binding [Main.Preview], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="#F8FAFC"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <Grid Background="#0B0F14">
                        <TextBlock x:Name="EmptyPreviewText"
                                   Text="{Binding [Main.SelectImage], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="#AAB4C2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <ScrollViewer x:Name="PreviewScroller"
                                      Background="#0B0F14"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="PreviewScroller_PreviewMouseWheel"
                                      PreviewMouseLeftButtonDown="PreviewScroller_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="PreviewScroller_PreviewMouseMove"
                                      PreviewMouseLeftButtonUp="PreviewScroller_PreviewMouseLeftButtonUp"
                                      SizeChanged="PreviewScroller_SizeChanged">
                            <Grid MinWidth="{Binding ElementName=PreviewScroller, Path=ViewportWidth}"
                                  MinHeight="{Binding ElementName=PreviewScroller, Path=ViewportHeight}">
                                <Image x:Name="PreviewImage"
                                       Stretch="Fill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.LayoutTransform>
                                        <ScaleTransform x:Name="PreviewScaleTransform" ScaleX="1" ScaleY="1" />
                                    </Image.LayoutTransform>
                                </Image>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
